DISCORD_TOKEN=your_token_here

# Language: en (default) or de
LANGUAGE=en

# YouTube cookie auth (optional, one of the two)
YDL_COOKIES_FILE=/path/to/cookies.txt
YDL_BROWSER=firefox

# DM-Bridge (KI-Dungeon-Master): HTTP-Server, über den Bot B fertige
# Audiodateien zum Abspielen schickt. Nur localhost.
DM_BRIDGE_HOST=127.0.0.1
DM_BRIDGE_PORT=8765
# Optional: URL von Bot B für Feedback-Loop-Rückmeldungen (z.B. http://127.0.0.1:8766)
DM_BOT_B_URL=
