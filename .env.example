DISCORD_TOKEN=your_token_here

# Language: en (default) or de
LANGUAGE=en

# YouTube cookie auth (optional, one of the two)
YDL_COOKIES_FILE=/path/to/cookies.txt
YDL_BROWSER=firefox

# DM-Bridge (KI-Dungeon-Master): HTTP-Server, über den Bot B fertige Audiodateien
# zum Abspielen schickt. Localhost (Default) = Pfad-Modus. Für getrennte Maschinen
# DM_BRIDGE_HOST auf die Tailscale-/LAN-IP (oder 0.0.0.0) setzen; dann schickt Bot B
# die WAV-Bytes übers Netz und dieser Bot spielt seine eigene Kopie (ADR 010).
DM_BRIDGE_HOST=127.0.0.1
DM_BRIDGE_PORT=8765
# Shared Secret, Pflicht sobald nicht-localhost gebunden. Muss exakt DMbots
# DM_BRIDGE_SECRET entsprechen. Leer + 127.0.0.1 = klassischer Pfad-Modus ohne Secret.
DM_BRIDGE_SECRET=
